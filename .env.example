NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
API_PORT=3103
POSTGRES_PORT=5432

# Required for startup:
# - DATABASE_URL
# - JWT_ACCESS_SECRET
# - JWT_REFRESH_SECRET

# Postgres (docker-compose example)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safeespace_mobile_server_db?schema=public

# Central Unit
CENTRAL_UNIT_BASE_URL=https://central-unit.example.com
CENTRAL_UNIT_INBOUND_AUTH_MODE=proxy

# Server TLS (needed if running HTTPS directly)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# Central Unit mTLS CA
CENTRAL_UNIT_MTLS_CA_CERT_PATH=./certs/ca.crt
CENTRAL_UNIT_MTLS_ALLOWED_SUBJECT_CN=central-unit

# If using proxy-terminated mTLS
CENTRAL_UNIT_PROXY_VERIFIED_HEADER=x-client-cert-verified
CENTRAL_UNIT_PROXY_SHARED_SECRET_HEADER=x-central-unit-proxy-secret
# Required by docker-compose interpolation (set to a strong random value)
CENTRAL_UNIT_PROXY_SHARED_SECRET=replace-with-strong-random-secret

# Firebase Cloud Messaging (FCM)
# FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-adminsdk.json
# FIREBASE_PROJECT_ID=your-firebase-project-id

# Auth + notifications
JWT_ACCESS_SECRET=your-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Optional hardening toggles
STRICT_REFRESH_TOKEN_USE=true
EXPOSE_EMAIL_VERIFICATION_TOKEN=false
ENABLE_ERROR_DEBUG=false
