    {
      "name": "Emergency",
      "item": [
        {
          "name": "POST /emergency/request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Capture emergencyRequestId when present', function () {",
                  "  const body = pm.response.json();",
                  "  if (body && body.data && body.data.id) pm.environment.set('emergencyRequestId', body.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"emergencyTypes\": [\"FIRE\"],\n  \"emergencyServices\": [\"FIRE_DEPARTMENT\"],\n  \"description\": \"Building fire reported\",\n  \"location\": { \"lat\": 30.0444, \"lng\": 31.2357 },\n  \"timestamp\": \"2026-01-29T12:34:56.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/emergency/request",
              "host": ["{{baseUrl}}"],
              "path": ["emergency", "request"]
            }
          }
        },
        {
          "name": "GET /emergency/request/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/emergency/request/{{emergencyRequestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["emergency", "request", "{{emergencyRequestId}}"]
            }
          }
        },
        {
          "name": "GET /emergency/requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}", "disabled": true }],
            "url": {
              "raw": "{{baseUrl}}/emergency/requests?status=QUEUED&limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["emergency", "requests"],
              "query": [
                { "key": "status", "value": "QUEUED" },
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "PATCH /emergency/request/:id/status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SENT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/emergency/request/{{emergencyRequestId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["emergency", "request", "{{emergencyRequestId}}", "status"]
            }
          }
        }
      ]
