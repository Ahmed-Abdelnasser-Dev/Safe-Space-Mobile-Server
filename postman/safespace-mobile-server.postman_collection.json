            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"location\": { \"lat\": 30.0444, \"lng\": 31.2357 },\n  \"message\": \"Accident reported from mobile app\",\n  \"occurredAt\": \"2026-01-29T12:34:56.000Z\",\n  \"media\": [\n    { \"type\": \"image\", \"url\": \"https://example.com/image.jpg\" }\n  ]\n}"
            },
